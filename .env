# Database Configuration
# Note: @ symbol in password is URL-encoded as %40
DATABASE_URL=postgresql://postgres:Adesh@localhost:5432/pmpml_optimization

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081

# Optimization Configuration
SOLVER_TIME_LIMIT_SEC=120
DEFAULT_MAX_DUTY_MIN=480

# Celery Configuration (Optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT Authentication Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# DRT Phase 3: Ghost Bus Suppression Configuration
GHOST_BUS_THRESHOLD=5
GHOST_BUS_ANALYSIS_DAYS=30
GHOST_BUS_MIN_OCCURRENCES=3
GHOST_BUS_AUTO_APPROVE=false
GHOST_BUS_ANALYSIS_TIME=02:00
